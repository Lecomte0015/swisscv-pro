{
  "name": "swisscv-pro-api",
  "version": "2.0.0",
  "description": "Backend API sécurisé pour SwissCV Pro avec Supabase Auth + D1",
  "main": "worker.js",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:create": "wrangler d1 create swisscv-db",
    "db:init": "wrangler d1 execute swisscv-db --file=./schema.sql",
    "db:migrations": "wrangler d1 migrations apply swisscv-db",
    "test": "echo \"Tests à implémenter\" && exit 0"
  },
  "keywords": [
    "cloudflare",
    "workers",
    "supabase",
    "d1",
    "jwt"
  ],
  "author": "Hermann - SwissCV Pro",
  "license": "PROPRIETARY",
  "dependencies": {
    "@supabase/supabase-js": "^2.39.0",
    "@anthropic-ai/sdk": "^0.32.1"
  },
  "devDependencies": {
    "wrangler": "^3.22.0"
  }
}
