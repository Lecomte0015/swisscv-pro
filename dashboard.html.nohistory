    <script>
        function toggleMobileMenu() {
            const m = document.getElementById('navbarMenu');
            const b = document.querySelector('.navbar-burger');
            m.classList.toggle('active');
            b.classList.toggle('active');
        }

        function toggleDropdown(event, button) {
            if (window.innerWidth <= 1024) {
                event.preventDefault();
                event.stopPropagation();
                const dropdown = button.closest('.navbar-dropdown');
                dropdown.classList.toggle('active');
            }
        }

        document.querySelectorAll('.navbar-link, .navbar-btn, .dropdown-item').forEach(l => {
            l.addEventListener('click', () => {
                if (window.innerWidth <= 1024) {
                    const m = document.getElementById('navbarMenu');
                    const b = document.querySelector('.navbar-burger');
                    m.classList.remove('active');
                    b.classList.remove('active');
                }
            })
        });

        (function () {
            const u = getUser();
            const planBadge = document.getElementById("planBadge");
            const cvToolsMenu = document.getElementById("cvToolsMenu");
            const teamLink = document.getElementById("teamLink");

            if (u && planBadge) {
                const tier = u.tier || 'free';
                planBadge.textContent = tier.charAt(0).toUpperCase() + tier.slice(1);
                planBadge.className = `plan-badge ${tier}`;

                // Afficher menu Outils CV pour Premium/Pro
                if (cvToolsMenu && (tier === 'premium' || tier === 'pro')) {
                    cvToolsMenu.style.display = 'inline-block';
                }

                // Afficher lien Équipe pour Pro
                if (tier === 'pro' && teamLink) {
                    teamLink.style.display = 'inline-block';
                }
            }
        })();
    </script>

    <!-- MAIN CONTENT -->
    <div style="max-width: 1400px; margin: 0 auto; padding: 120px 24px 40px;">
        <div id="analyticsSection">
