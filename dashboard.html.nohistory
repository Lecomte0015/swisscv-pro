            <style>
                /* Responsive pour Analytics Dashboard */
                @media (max-width: 768px) {
                    .kpi-grid {
                        grid-template-columns: 1fr !important;
                        gap: 16px !important;
                    }

                    .charts-grid {
                        grid-template-columns: 1fr !important;
                        gap: 20px !important;
                    }

                    .kpi-card {
                        padding: 20px !important;
                    }

                    canvas {
                        max-height: 250px !important;
                    }
                }

                @media (min-width: 769px) and (max-width: 1024px) {
                    .kpi-grid {
                        grid-template-columns: repeat(2, 1fr) !important;
                    }

                    .charts-grid {
                        grid-template-columns: 1fr !important;
                    }
                }
            </style>

            <!-- Analysis History Section Removed -->
            <div class="empty-state">
                <div style="font-size: 64px;">📄</div>
                <h2>Aucune analyse pour le moment</h2>
                <p>Analysez votre premier CV pour voir l'historique ici</p>
                <a href="app.html" class="btn-refresh"
                    style="display: inline-block; text-decoration: none; margin-top: 16px;">Analyser un CV</a>
            </div>

            <div id="historyGrid" class="offers-grid" style="display:none;"></div>

            <hr style="margin: 60px 0; border: none; border-top: 2px solid #E0E0E0;">

            <!-- Section offres déplacée vers job-search.html -->


            <script>
                (async function () {
                    console.log("Dashboard chargé - VERSION 2025-12-14-10:35");
                    const token = getToken();
                    if (!token) {
                        console.log("Pas de token - Redirection login");
                        window.location.href = "login.html";
                        return;
                    }

                    try {
                        const response = await authenticatedFetch("/auth/me");
                        const data = await response.json();

                        if (data.success) {
                            console.log("Auth OK:", data.user.email);
                            localStorage.setItem("swisscv_user", JSON.stringify(data.user));
                            const badge = document.getElementById("userBadge");
                            console.log("✅ APRÈS Auth OK - Tentative chargement historique...");
                            // Charger historique analyses
                            if (typeof loadAnalysisHistory === 'function') {
                                console.log("🔄 Appel loadAnalysisHistory...");
                                loadAnalysisHistory();
                            } else {
                                console.error("❌ loadAnalysisHistory non définie!");
                            } if (badge && data.user) {
                                if (data.user.tier === "premium" || data.user.tier === "pro") {
                                    badge.className = "navbar-badge premium";
                                    badge.textContent = data.user.tier === "pro" ? "Pro" : "Premium";
                                } else {
                                    badge.className = "navbar-badge free";
                                    badge.textContent = "Free";
                                }
                            }
                        } else {
                            throw new Error("Auth failed");
                        }
                    } catch (error) {
                        console.error("Erreur auth:", error);
                        logout();
                    }
                })();

                // Charger l'historique des analyses
                async function loadAnalysisHistory() {
                    const historyLoading = document.getElementById('historyLoading');
                    const historyEmpty = document.getElementById('historyEmpty');
                    const historyGrid = document.getElementById('historyGrid');

                    historyLoading.style.display = 'block';
                    historyEmpty.style.display = 'none';
                    historyGrid.style.display = 'none';

                    try {
                        console.log("🔍 Appel API /analyses/history...");
                        console.log("🔍 Token présent:", !!localStorage.getItem('swisscv_token'));
                        const response = await authenticatedFetch('/analyses/history');
                        const data = await response.json();
                        console.log("📊 Réponse analyses/history:", data);
                        console.log("📊 Nombre analyses:", data.analyses?.length);

                        if (data.success && data.analyses && data.analyses.length > 0) {
                            historyGrid.innerHTML = data.analyses.map(analysis => `
                        <div class="offer-card" style="position: relative;">
                            <button onclick="event.stopPropagation(); deleteAnalysis('${analysis.id}')" 
                                    style="position: absolute; top: 12px; right: 12px; background: #FFE5E5; border: none; border-radius: 50%; width: 32px; height: 32px; cursor: pointer; display: flex; align-items: center; justify-content: center; color: #D50000; font-size: 18px; font-weight: bold; transition: all 0.2s;"
                                    onmouseover="this.style.background='#D50000'; this.style.color='white';"
                                    onmouseout="this.style.background='#FFE5E5'; this.style.color='#D50000';"
                                    title="Supprimer cette analyse">
                                ×
                            </button>
                            <div onclick="showAnalysisDetail('${analysis.id}')" style="cursor: pointer;">
                                <div class="offer-title">${analysis.filename || 'CV analysé'}</div>
                                <div class="offer-company">Analysé le ${analysis.createdAt ? new Date(analysis.createdAt * 1000).toLocaleDateString('fr-CH', { year: 'numeric', month: 'long', day: 'numeric' }) : 'Date inconnue'}</div>
                                <div style="display: flex; gap: 16px; margin: 16px 0;">
                                    <div style="flex: 1; text-align: center; padding: 12px; background: #F5F5F5; border-radius: 8px;">
                                        <div style="font-size: 24px; font-weight: 700; color: #D50000;">${analysis.score}</div>
                                        <div style="font-size: 12px; color: #666;">Score CV</div>
                                    </div>
                                    <div style="flex: 1; text-align: center; padding: 12px; background: #F5F5F5; border-radius: 8px;">
                                        <div style="font-size: 24px; font-weight: 700; color: #10b981;">${analysis.atsScore}</div>
                                        <div style="font-size: 12px; color: #666;">Score ATS</div>
                                    </div>
                                </div>
                                <div class="offer-footer">
                                    <span class="offer-source">${analysis.strongPoints.length} points forts</span>
                                    <button class="btn-view" onclick="event.stopPropagation(); showAnalysisDetail('${analysis.id}')">Voir détails</button>
                                </div>
                            </div>
                        </div>
                    `).join('');

                            historyGrid.style.display = 'grid';

                            // Stocker les analyses pour le modal
                            window.analysesData = data.analyses;
                        } else {
                            historyEmpty.style.display = 'block';
                        }
                    } catch (error) {
                        console.error('Erreur chargement historique:', error);
                        historyEmpty.style.display = 'block';
                    } finally {
                        historyLoading.style.display = 'none';
                    }
                }

                // Afficher les détails d'une analyse
                function showAnalysisDetail(analysisId) {
                    const analysis = window.analysesData?.find(a => a.id === analysisId);
                    if (!analysis) return;

                    const modal = document.createElement('div');
                    modal.style.cssText = 'position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.7); z-index: 10000; display: flex; align-items: center; justify-content: center; padding: 20px;';

                    modal.innerHTML = `
                <div style="background: white; border-radius: 12px; max-width: 800px; width: 100%; max-height: 90vh; overflow-y: auto; padding: 32px;">
                    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 24px;">
                        <h2 style="font-size: 24px; font-weight: 700;">${analysis.filename}</h2>
                        <button onclick="this.closest('div[style*=fixed]').remove()" style="background: none; border: none; font-size: 32px; cursor: pointer; color: #666;">&times;</button>
                    </div>
                    
                    <div style="display: flex; gap: 16px; margin-bottom: 24px;">
                        <div style="flex: 1; text-align: center; padding: 16px; background: #F5F5F5; border-radius: 8px;">
                            <div style="font-size: 32px; font-weight: 700; color: #D50000;">${analysis.score}/100</div>
                            <div style="font-size: 14px; color: #666;">Score CV</div>
                        </div>
                        <div style="flex: 1; text-align: center; padding: 16px; background: #F5F5F5; border-radius: 8px;">
                            <div style="font-size: 32px; font-weight: 700; color: #10b981;">${analysis.atsScore}/100</div>
                            <div style="font-size: 14px; color: #666;">Score ATS</div>
                        </div>
                    </div>
                    
                    <div style="margin-bottom: 24px;">
                        <h3 style="font-size: 18px; font-weight: 700; margin-bottom: 12px;">✅ Points forts</h3>
                        <ul style="list-style: none; padding: 0;">
                            ${analysis.strongPoints.map(point => `<li style="padding: 8px 0; border-bottom: 1px solid #E0E0E0;">• ${point}</li>`).join('')}
                        </ul>
                    </div>
                    
                    ${analysis.improvements ? `
                        <div style="margin-bottom: 24px;">
                            <h3 style="font-size: 18px; font-weight: 700; margin-bottom: 12px;">💡 Points à améliorer</h3>
                            <ul style="list-style: none; padding: 0;">
                                ${analysis.improvements.map(point => `<li style="padding: 8px 0; border-bottom: 1px solid #E0E0E0;">• ${point}</li>`).join('')}
                            </ul>
                        </div>
                    ` : ''}
                    
                    ${analysis.swissAdvice ? `
                        <div style="margin-bottom: 24px;">
                            <h3 style="font-size: 18px; font-weight: 700; margin-bottom: 12px;">🇨🇭 Conseils marché suisse</h3>
                            <p style="padding: 16px; background: #F5F5F5; border-radius: 8px; line-height: 1.6;">${analysis.swissAdvice}</p>
                        </div>
                    ` : ''}
                    
                    <div>
                        <h3 style="font-size: 18px; font-weight: 700; margin-bottom: 12px;">🔑 Mots-clés</h3>
                        <div style="display: flex; flex-wrap: wrap; gap: 8px;">
                            ${analysis.keywords.map(keyword => `<span style="padding: 6px 12px; background: #E0E0E0; border-radius: 16px; font-size: 14px;">${keyword}</span>`).join('')}
                        </div>
                    </div>
                </div>
            `;

                    document.body.appendChild(modal);
                    modal.onclick = (e) => { if (e.target === modal) modal.remove(); };
                }

                // Charger l'historique au démarrage

                // Supprimer une seule analyse
                async function deleteAnalysis(analysisId) {
                    const confirmed = await showConfirm(
                        'Cette analyse sera définitivement supprimée.',
                        'Supprimer l\'analyse',
                        true // danger
                    );

                    if (!confirmed) return;

                    try {
                        const token = getToken();
                        const response = await fetch(`${API_BASE}/cv-analyses/${analysisId}`, {
                            method: 'DELETE',
                            headers: {
                                'Authorization': `Bearer ${token}`
                            }
                        });

                        const data = await response.json();
                        if (data.success) {
                            await showSuccess('Analyse supprimée avec succès');
                            loadAnalysisHistory();
                        } else {
                            await showError(data.error || 'Impossible de supprimer l\'analyse');
                        }
                    } catch (error) {
                        await showError('Erreur de connexion');
                    }
                }

                // Supprimer tout l'historique
                async function deleteAllHistory() {
                    const confirmed = await showConfirm(
                        'Toutes vos analyses seront définitivement supprimées.\n\nCette action est irréversible.',
                        '⚠️ Supprimer tout l\'historique',
                        true // danger
                    );

                    if (!confirmed) return;

                    try {
                        const response = await authenticatedFetch('/analyses/history', {
                            method: 'DELETE'
                        });

                        if (response.ok) {
                            await showSuccess('Historique supprimé avec succès !');
                            loadAnalysisHistory();
                        } else {
                            const error = await response.json();
                            await showError(error.error || 'Impossible de supprimer l\'historique');
                        }
                    } catch (error) {
                        await showError('Erreur de connexion');
                    }
                }

                // Charger l'historique au démarrage - APRÈS chargement DOM
                document.addEventListener('DOMContentLoaded', function () {
                    loadAnalysisHistory();
                });
            </script>

            <!-- Système de Notifications -->
            <script src="public/js/notifications.js"></script>
            <script src="public/js/favorites-badge.js"></script>
            <script src="public/js/dashboard-analytics.js?v=2"></script>
</body>

</html>
<script>
    // Force le chargement de l'historique après que tout soit chargé
    window.addEventListener('load', function () {
        <script src="public/js/force-history-load.js?v=20251214-1037"></script> console.log('🔄 Force chargement
historique...');
setTimeout(() => {
if (typeof loadAnalysisHistory === 'function') {
console.log('✅ loadAnalysisHistory trouvée, appel...');
loadAnalysisHistory();
} else {
console.error('❌ loadAnalysisHistory non trouvée!');
}
}, 1000); // Attendre 1 seconde pour être sûr que tout est chargé
});
</script>