        function setupPremiumLinks() {
            const user = getUser();
            const isPremium = user && (user.tier === 'premium' || user.tier === 'pro');

            const premiumLinks = document.querySelectorAll('.nav-link.premium-only');

            if (!isPremium) {
                premiumLinks.forEach(link => {
                    link.classList.add('locked');
                    link.addEventListener('click', (e) => {
                        e.preventDefault();
                        alert('⚠️ Cette fonctionnalité est réservée aux utilisateurs Premium.\n\nPassez à Premium pour débloquer :\n✅ Recherche d\'offres d\'emploi\n✅ Suivi des candidatures\n✅ Templates CV suisses\n\n👉 Cliquez sur "Tarifs" pour en savoir plus.');
                        window.location.href = 'pricing.html';
                    });
                });
            } else {
                // Supprimer le "locked" si Premium
                premiumLinks.forEach(link => {
                    link.classList.remove('locked');
                });
            }
        }

        const dropZone = document.getElementById('dropZone');
        const fileInput = document.getElementById('fileInput');
        const fileInfo = document.getElementById('fileInfo');
        const analyzeBtn = document.getElementById('analyzeBtn');

        dropZone.addEventListener('dragover', (e) => {
            e.preventDefault();
            dropZone.classList.add('dragover');
        });

        dropZone.addEventListener('dragleave', () => {
            dropZone.classList.remove('dragover');
        });

        dropZone.addEventListener('drop', (e) => {
            e.preventDefault();
            dropZone.classList.remove('dragover');
            if (e.dataTransfer.files.length > 0) {
                handleFileSelect(e.dataTransfer.files[0]);
            }
        });

        dropZone.addEventListener('click', (e) => {
            if (e.target !== fileInput && !e.target.closest('.btn-upload')) {
                fileInput.click();
            }
        });

        fileInput.addEventListener('change', (e) => {
            if (e.target.files.length > 0) {
                handleFileSelect(e.target.files[0]);
            }
        });

        function handleFileSelect(file) {
            const validTypes = [
                'application/pdf',
                'application/msword',
                'application/vnd.openxmlformats-officedocument.wordprocessingml.document',
                'text/plain'
            ];

            if (!validTypes.includes(file.type)) {
                alert('❌ Format non supporté. Utilisez PDF, DOC, DOCX ou TXT.');
                return;
            }

            const maxSize = 10 * 1024 * 1024;
            if (file.size > maxSize) {
                alert('❌ Fichier trop volumineux. Maximum 10 MB.');
                return;
            }

            selectedFile = file;
            document.getElementById('fileName').textContent = file.name;
            document.getElementById('fileSize').textContent = formatFileSize(file.size);
            fileInfo.classList.add('show');
            analyzeBtn.disabled = false;
            console.log('✅ Fichier sélectionné:', file.name);
        }

        function formatFileSize(bytes) {
            if (bytes === 0) return '0 Bytes';
            const k = 1024;
            const sizes = ['Bytes', 'KB', 'MB'];
            const i = Math.floor(Math.log(bytes) / Math.log(k));
            return Math.round(bytes / Math.pow(k, i) * 100) / 100 + ' ' + sizes[i];
        }

        // ============================================================
        // ANALYSE CV
        // ============================================================

        analyzeBtn.addEventListener('click', analyzeCV);

        async function analyzeCV() {
            if (!selectedFile) {
                alert('❌ Veuillez sélectionner un fichier.');
                return;
            }

            try {
                console.log('🚀 Analyse:', selectedFile.name);
                const canAnalyzeResult = await canAnalyze();

                if (!canAnalyzeResult.allowed) {
                    // This case should ideally be handled by the backend returning 403
                    // but keeping this for explicit client-side checks if any.
                    if (canAnalyzeResult.reason === 'no_auth') {
                        alert('Veuillez vous connecter pour analyser votre CV.');
                        window.location.href = 'login.html';
                    } else {
                        showLimitReachedModal();
                    }
                    return;
                }

                // ✅ Afficher le loading avec animation
                document.getElementById('loadingOverlay').classList.add('show');

                // ✅ Extraction avec la nouvelle fonction robuste
                let cvText;
                try {
                    cvText = await extractTextFromFile(selectedFile);
                    console.log('📝 Texte extrait:', cvText.length, 'chars');

                    // Sauvegarder pour optimisation
                    currentCVText = cvText;
                } catch (extractError) {
                    console.error('❌ Erreur extraction:', extractError);
                    document.getElementById('loadingOverlay').classList.remove('show');
                    alert('❌ ' + extractError.message);
                    return;
                }

                if (!cvText || cvText.length < 100) {
                    throw new Error('Texte extrait trop court (minimum 100 caractères).');
                }

                const hasPhoto = document.getElementById('hasPhotoCheckbox').checked;
                const userId = generateUserId();

                console.log('📤 Envoi à l\'API...');

                const token = getToken();
                if (!token) {
                    throw new Error('Non authentifié. Veuillez vous connecter.');
                }

                const response = await fetch(`${API_BASE}/analyze-cv-text`, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'Authorization': `Bearer ${token}`
                    },
                    body: JSON.stringify({
                        cvText,
                        filename: selectedFile.name,
                        hasPhoto: hasPhoto
                    })
                });

                console.log('📥 Réponse:', response.status);

                if (!response.ok) {
                    const errorText = await response.text();
                    throw new Error(`${response.status}: ${errorText}`);
                }

                const result = await response.json();
                console.log('✅ Résultat:', result);

                // ✅ Le worker retourne { success: true, analysis: {...} }
                const analysis = result.analysis || result;

                if (!analysis.score) {
                    throw new Error('Résultat incomplet');
                }

                // Plus besoin d'incrémenter manuellement, le worker le fait
                await updateRemainingCount();

                currentAnalysisResult = analysis;
                saveAnalysis({
                    fileName: selectedFile.name,
                    score: analysis.score,
                    atsScore: analysis.atsScore || null,
                    strongPoints: analysis.strongPoints || [],
                    improvements: analysis.improvements || [],
                    swissAdvice: analysis.swissAdvice || []
                });

                // ✅ Masquer le loading
                document.getElementById('loadingOverlay').classList.remove('show');

                // ✅ Afficher les résultats
                displayResults(analysis);

                // Scroll vers les résultats
                document.getElementById('resultsSection').scrollIntoView({ behavior: 'smooth' });

                if (typeof gtag !== 'undefined') {
                    gtag('event', 'cv_analyzed', {
                        'event_category': 'analysis',
                        'user_type': canAnalyzeResult.reason
                    });
                }

            } catch (error) {
                console.error('❌ ERREUR:', error);
                document.getElementById('loadingOverlay').classList.remove('show');

                // Vérifier si c'est une erreur de limite atteinte
                if (error.message.includes('403') && error.message.includes('Limite gratuite atteinte')) {
                    showLimitReachedModal();
                } else {
                    let errorMessage = '❌ Erreur lors de l\'analyse.\n\n';

                    if (error.message.includes('401')) {
                        errorMessage += 'Veuillez vous reconnecter.';
                        setTimeout(() => window.location.href = 'login.html', 2000);
                    } else if (error.message.includes('500')) {
                        errorMessage += 'Erreur serveur. Réessayez dans quelques instants.';
                    } else if (error.message.includes('Network')) {
                        errorMessage += 'Problème de connexion. Vérifiez votre internet.';
                    } else {
                        errorMessage += error.message || 'Erreur inconnue';
                    }

                    alert(errorMessage);
                }

                if (typeof gtag !== 'undefined') {
                    gtag('event', 'cv_analysis_error', {
                        'event_category': 'error'
                    });
                }
            }
        }

        // ============================================================
        // ✅ AFFICHAGE DES RÉSULTATS AVEC ANIMATION
        // ============================================================

        function displayResults(result) {
            console.log('📊 Affichage des résultats:', result);

            // Afficher la section résultats
            document.getElementById('resultsSection').classList.add('show');

            // ✅ Animer le score avec la gauge circulaire
            const scoreValue = result.score || 0;
            animateScore(scoreValue);

            // Points forts
            const strengthsList = document.getElementById('strengthsList');
            strengthsList.innerHTML = '';
            if (result.strongPoints && result.strongPoints.length > 0) {
                result.strongPoints.forEach(s => {
                    const li = document.createElement('li');
                    li.textContent = s;
                    strengthsList.appendChild(li);
                });
            } else {
                strengthsList.innerHTML = '<li style="color:#999;font-style:italic">Aucun point fort disponible</li>';
            }

            // Améliorations
            const improvementsList = document.getElementById('improvementsList');
            improvementsList.innerHTML = '';
            if (result.improvements && result.improvements.length > 0) {
                result.improvements.forEach(i => {
                    const li = document.createElement('li');
                    li.textContent = i;
                    improvementsList.appendChild(li);
                });
            } else {
                improvementsList.innerHTML = '<li style="color:#999;font-style:italic">Aucune amélioration disponible</li>';
            }

            // Conseils Suisse
            const swissAdviceList = document.getElementById('swissAdviceList');
            swissAdviceList.innerHTML = '';
            if (result.swissAdvice) {
                // Si c'est un array, afficher chaque élément
                if (Array.isArray(result.swissAdvice)) {
                    result.swissAdvice.forEach(a => {
                        const li = document.createElement('li');
                        li.textContent = a;
                        swissAdviceList.appendChild(li);
                    });
                } else {
                    // Si c'est une string, afficher directement
                    const li = document.createElement('li');
                    li.textContent = result.swissAdvice;
                    swissAdviceList.appendChild(li);
                }
            } else {
                swissAdviceList.innerHTML = '<li style="color:#999;font-style:italic">Aucun conseil disponible</li>';
            }

            // Score ATS
            if (result.ats_score) {
                const ats = document.getElementById('atsSection');
                if (ats) {
                    ats.style.display = 'block';
                    document.getElementById('atsScoreValue').textContent = result.ats_score + '%';
                }
            }

            console.log('✅ Affichage terminé');

            // Afficher le bouton optimisation pour Premium/Pro
            updateOptimizeButton();
        }

