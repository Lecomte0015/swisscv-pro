            color: white;
        }

        .plan-badge.pro {
            background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
            color: white;
        }

        /* Responsive Mobile */
        @media (max-width: 1024px) {
            .navbar-dropdown {
                width: 100%;
            }

            .dropdown-toggle {
                width: 100%;
                justify-content: space-between;
                color: #0D0D0D;
                /* Ensure text color is visible on mobile */
