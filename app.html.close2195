    <script>
        // ✅ Configuration PDF.js
        if (typeof pdfjsLib !== 'undefined') {
            pdfjsLib.GlobalWorkerOptions.workerSrc = 'https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.worker.min.js';
            console.log('✅ PDF.js chargé');
        }

        console.log('🚀 SwissCV Pro FIXED - Version corrigée complète');

        let selectedFile = null;
        let currentAnalysisResult = null;
        let currentCVText = '';

        // ============================================================
        // FONCTIONS UTILITAIRES
        // ============================================================

        function generateUserId() {
            const fp = [
                navigator.userAgent,
                navigator.language,
                screen.width + 'x' + screen.height,
                new Date().getTimezoneOffset()
            ].join('|');
            const hash = fp.split('').reduce((acc, c) => ((acc << 5) - acc) + c.charCodeAt(0), 0);
            return `user_${Math.abs(hash)}`;
        }

        // ============================================================
        // ✅ FONCTIONS AUTH déjà définies au début de <body>
        // ============================================================

        // getToken(), getUser(), logout() déjà définis au début

        function isPaidUser() {
            const user = getUser();
            if (!user) return false;
            return user.tier === 'premium' || user.tier === 'pro';
        }

        async function canAnalyze() {
            // Simplifié : on laisse le backend gérer les limites
            // Le backend retournera une erreur 403 si la limite est atteinte
            const token = localStorage.getItem('swisscv_token');
            if (!token) {
                console.error('❌ Pas de token JWT');
                return { allowed: false, reason: 'no_auth' };
            }

            return { allowed: true, reason: 'unknown' };
        }

        async function incrementAnalysisCount(apiEndpoint) {
            const userId = generateUserId();
            try {
                await fetch(`${apiEndpoint}/increment-analysis`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ userId })
                });
            } catch (e) {
                console.error('Erreur incrémentation:', e);
            }
        }

        async function updateRemainingCount() {
            // Simplifié : on ne vérifie plus côté client
            // Le backend gère les limites et retourne une erreur 403 si dépassé
            return { remaining: -1 }; // -1 = inconnu
        }

        function displayRemainingCount(remaining) {
            const container = document.getElementById('remainingAnalyses');
            if (!container) return;
            if (remaining === 0) {
                container.innerHTML = `<div style="background:#FFEBEE;border:2px solid #D50000;padding:16px;border-radius:8px;text-align:center">
                    <div style="font-size:18px;font-weight:700;color:#D50000;margin-bottom:8px">⚠️ Limite atteinte</div>
                    <p style="font-size:14px;color:#666;margin-bottom:12px">Vous avez utilisé vos 2 analyses gratuites</p>
                    <a href="pricing.html" style="display:inline-block;background:#D50000;color:white;padding:12px 24px;border-radius:6px;text-decoration:none;font-weight:600">🚀 Passer à Premium</a>
                </div>`;
            } else {
                container.innerHTML = `<div style="background:#FFF3E0;border:2px solid #FFB300;padding:12px;border-radius:6px;text-align:center">
                    <span style="font-weight:700;color:#E65100">${remaining} analyse${remaining > 1 ? 's' : ''} gratuite${remaining > 1 ? 's' : ''} restante${remaining > 1 ? 's' : ''}</span>
                </div>`;
            }
        }

        function showLimitReachedModal() {
            // Créer le modal s'il n'existe pas
            let modal = document.getElementById('limitModal');
            if (!modal) {
                modal = document.createElement('div');
                modal.id = 'limitModal';
                modal.style.cssText = 'display: none; position: fixed; z-index: 10000; left: 0; top: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.6); overflow-y: auto;';
                modal.innerHTML = `
                    <div style="background: white; margin: 5% auto; padding: 0; border-radius: 12px; max-width: 450px; box-shadow: 0 8px 32px rgba(0,0,0,0.3); position: relative;">
                        <div style="text-align: center; padding: 32px 24px;">
                            <div style="font-size: 56px; margin-bottom: 16px;">🔒</div>
                            <h2 style="font-size: 24px; margin-bottom: 12px; color: #0D0D0D;">Limite gratuite atteinte</h2>
                            <p style="color: #666; font-size: 15px; margin-bottom: 24px; line-height: 1.5;">Vous avez utilisé vos 2 analyses gratuites.<br>Passez à Premium pour continuer !</p>
                            
                            <div style="background: linear-gradient(135deg, #FFD700 0%, #FFA500 100%); padding: 20px; border-radius: 10px; margin-bottom: 24px;">
                                <div style="font-size: 32px; font-weight: 700; color: #000; margin-bottom: 6px;">9.90 CHF/mois</div>
                                <div style="color: #333; font-size: 13px; font-weight: 600;">✅ Analyses illimitées<br>✅ Lettres de motivation<br>✅ Export PDF</div>
                            </div>
                            
                            <button onclick="window.location.href='pricing.html'" style="width: 100%; background: #D50000; color: white; padding: 16px; border: none; border-radius: 8px; font-size: 16px; font-weight: 700; cursor: pointer; margin-bottom: 10px; transition: all 0.2s; box-shadow: 0 4px 16px rgba(213, 0, 0, 0.3);" onmouseover="this.style.background='#B80000'; this.style.transform='translateY(-2px)'" onmouseout="this.style.background='#D50000'; this.style.transform='translateY(0)'">
                                🚀 Passer à Premium
                            </button>
                            <button onclick="document.getElementById('limitModal').style.display='none'" style="width: 100%; background: white; color: #666; padding: 14px; border: 2px solid #E6E6E6; border-radius: 8px; font-size: 15px; font-weight: 600; cursor: pointer; transition: all 0.2s;" onmouseover="this.style.borderColor='#D50000'; this.style.color='#D50000'" onmouseout="this.style.borderColor='#E6E6E6'; this.style.color='#666'">
                                Fermer
                            </button>
                        </div>
                    </div>
                `;
                document.body.appendChild(modal);

                // Fermer en cliquant sur le fond
                modal.onclick = function (e) {
                    if (e.target === modal) {
                        modal.style.display = 'none';
                    }
                };
            }
            modal.style.display = 'block';
        }

        function showUpgradeModal(feature) {
            alert(`${feature} est une fonctionnalité Premium.`);
            window.location.href = 'pricing.html';
        }

        function saveAnalysis(data) {
            try {
                const analyses = JSON.parse(localStorage.getItem('swisscv_analyses') || '[]');
                analyses.unshift({
                    id: Date.now(),
                    date: new Date().toISOString(),
                    ...data
                });
                localStorage.setItem('swisscv_analyses', JSON.stringify(analyses.slice(0, 20)));
                console.log('✅ Analyse sauvegardée');
            } catch (e) {
                console.error('Erreur sauvegarde:', e);
            }
        }

        // ============================================================
        // ✅ NOUVELLE FONCTION : EXTRACTION PDF ROBUSTE AVEC PDF.JS
        // ============================================================

        async function extractTextFromPDF(file) {
            console.log('📄 Extraction PDF avec PDF.js...');

            return new Promise(async (resolve, reject) => {
                try {
                    // Lire le fichier en ArrayBuffer
                    const arrayBuffer = await file.arrayBuffer();

                    // Charger le PDF
                    const pdf = await pdfjsLib.getDocument({ data: arrayBuffer }).promise;
                    console.log(`📄 PDF chargé: ${pdf.numPages} pages`);

                    let fullText = '';

                    // Extraire le texte de chaque page
                    for (let pageNum = 1; pageNum <= pdf.numPages; pageNum++) {
                        const page = await pdf.getPage(pageNum);
                        const textContent = await page.getTextContent();
                        const pageText = textContent.items.map(item => item.str).join(' ');
                        fullText += pageText + '\n';
                    }

                    // Nettoyer le texte
                    const cleanText = fullText
                        .replace(/\s+/g, ' ')
                        .trim()
                        .substring(0, 8000); // Limite à 8000 caractères

                    console.log(`✅ Texte extrait: ${cleanText.length} caractères`);

                    if (cleanText.length < 100) {
                        reject(new Error('PDF vide ou illisible. Essayez un autre format.'));
                        return;
                    }

                    resolve(cleanText);

                } catch (error) {
                    console.error('❌ Erreur extraction PDF:', error);
                    reject(new Error('Impossible de lire le PDF. Vérifiez qu\'il n\'est pas protégé.'));
                }
            });
        }

        // ============================================================
        // ✅ FONCTION D'EXTRACTION MULTI-FORMAT AMÉLIORÉE
        // ============================================================

        async function extractTextFromFile(file) {
            console.log('📝 Extraction du texte:', file.type);

            // Texte brut
            if (file.type === 'text/plain') {
                return new Promise((resolve, reject) => {
                    const reader = new FileReader();
                    reader.onload = (e) => {
                        const text = e.target.result;
                        if (text.length < 100) {
                            reject(new Error('Fichier trop court (minimum 100 caractères).'));
                            return;
                        }
                        resolve(text.substring(0, 8000));
                    };
                    reader.onerror = () => reject(new Error('Erreur lecture fichier'));
                    reader.readAsText(file);
                });
            }

            // PDF - Utiliser PDF.js
            if (file.type === 'application/pdf') {
                return await extractTextFromPDF(file);
            }

            // DOC/DOCX - Extraction basique
            if (file.type.includes('word') || file.type.includes('document')) {
                return new Promise((resolve, reject) => {
                    const reader = new FileReader();
                    reader.onload = (e) => {
                        try {
                            let text = e.target.result;
                            // Nettoyer le texte des caractères binaires
                            const cleanText = text
                                .replace(/[^\x20-\x7E\n\r\t]/g, ' ')
                                .replace(/\s+/g, ' ')
                                .trim()
                                .substring(0, 8000);

                            if (cleanText.length < 100) {
                                reject(new Error('Impossible d\'extraire suffisamment de texte. Utilisez un PDF ou TXT.'));
                                return;
                            }
                            resolve(cleanText);
                        } catch (error) {
                            reject(error);
                        }
                    };
                    reader.onerror = () => reject(new Error('Erreur lecture fichier'));
                    reader.readAsText(file);
                });
            }

            throw new Error('Format de fichier non supporté');
        }

        // ============================================================
        // ✅ NOUVELLE FONCTION : ANIMATION GAUGE CIRCULAIRE
        // ============================================================

        function drawScoreGauge(score) {
            const canvas = document.getElementById('scoreCanvas');
            if (!canvas) return;

            const ctx = canvas.getContext('2d');
            const centerX = canvas.width / 2;
            const centerY = canvas.height / 2;
            const radius = 120;
            const lineWidth = 20;

            // Couleur en fonction du score
            let gaugeColor;
            if (score >= 80) {
                gaugeColor = '#00C853'; // Vert
            } else if (score >= 60) {
                gaugeColor = '#FFB300'; // Orange
            } else {
                gaugeColor = '#D50000'; // Rouge
            }

            // Effacer le canvas
            ctx.clearRect(0, 0, canvas.width, canvas.height);

            // Dessiner le cercle de fond (gris)
            ctx.beginPath();
            ctx.arc(centerX, centerY, radius, 0, 2 * Math.PI);
            ctx.strokeStyle = '#E0E0E0';
            ctx.lineWidth = lineWidth;
            ctx.stroke();

            // Dessiner le cercle de progression (animé)
            const startAngle = -Math.PI / 2; // Commence en haut
            const endAngle = startAngle + (2 * Math.PI * score / 100);

            ctx.beginPath();
            ctx.arc(centerX, centerY, radius, startAngle, endAngle);
            ctx.strokeStyle = gaugeColor;
            ctx.lineWidth = lineWidth;
            ctx.lineCap = 'round';
            ctx.stroke();

            // Ajouter une ombre/glow
            ctx.shadowColor = gaugeColor;
            ctx.shadowBlur = 15;
            ctx.stroke();
            ctx.shadowBlur = 0;
        }

        // Animation progressive du score
        function animateScore(targetScore) {
            const scoreElement = document.getElementById('scoreValue');
            const duration = 2000; // 2 secondes
            const fps = 60;
            const frames = duration / (1000 / fps);
            const increment = targetScore / frames;
            let currentScore = 0;
            let frame = 0;

            const animate = () => {
                frame++;
                currentScore = Math.min(currentScore + increment, targetScore);

                // Mettre à jour le texte
                scoreElement.textContent = Math.round(currentScore);

                // Dessiner la gauge
                drawScoreGauge(currentScore);

                if (frame < frames) {
                    requestAnimationFrame(animate);
                } else {
                    // Animation terminée
                    scoreElement.textContent = targetScore;
                    drawScoreGauge(targetScore);
                }
            };

            animate();
        }

        // ============================================================
        // UI ET INTERACTIONS
        // ============================================================

        function updateUIForUserRole() {
            const user = getUser();
            const role = user ? user.tier : 'free';
            const planBadge = document.getElementById('planBadge');
            const planIcon = document.getElementById('planIcon');
            const planText = document.getElementById('planText');
            const dashboardLink = document.getElementById('dashboardLink');

            console.log('👤 Rôle utilisateur:', role);

            if (!dashboardLink) {
                console.error('❌ Element dashboardLink non trouvé');
                return;
            }

            // Supprimer tous les anciens event listeners
            const newDashboardLink = dashboardLink.cloneNode(true);
            dashboardLink.parentNode.replaceChild(newDashboardLink, dashboardLink);

            planBadge.className = 'plan-badge ' + role;

            if (role === 'pro') {
                planIcon.textContent = '💎';
                planText.textContent = 'Pro';
                newDashboardLink.style.display = 'inline-block';
                newDashboardLink.addEventListener('click', function (e) {
                    e.preventDefault();
                    // Déjà sur app.html, pas besoin de rediriger
                    console.log('✅ Déjà sur le dashboard Pro');
                });
            } else if (role === 'premium') {
                planIcon.textContent = '✨';
                planText.textContent = 'Premium';
                newDashboardLink.style.display = 'inline-block';
                newDashboardLink.addEventListener('click', function (e) {
                    e.preventDefault();
                    // Déjà sur app.html, pas besoin de rediriger
                    console.log('✅ Déjà sur le dashboard Premium');
                });
            } else {
                planIcon.textContent = '🆓';
                planText.textContent = 'Free';
                newDashboardLink.style.display = 'none';
            }

            console.log('✅ UI mise à jour pour rôle:', role);
        }

