                padding: 12px 20px;
                border-left: 3px solid #D50000;
            }
        }

        @media (max-width: 480px) {
            .navbar-brand {
                font-size: 18px
            }

            .navbar-link {
                font-size: 16px;
                padding: 12px
            }
        }

        /* Menus déroulants */
        .navbar-dropdown {
            position: relative;
            display: inline-block;
        }

        .dropdown-toggle {
            background: none;
            border: none;
            color: #0D0D0D;
            /* Changed from white to match existing navbar-link color */
            font-size: 14px;
            /* Changed from 16px to match existing navbar-link font-size */
            font-weight: 600;
            /* Added to match existing navbar-link font-weight */
            cursor: pointer;
            display: flex;
            align-items: center;
            gap: 4px;
            padding: 8px 16px;
            /* Changed from 12px 16px to match existing navbar-link padding */
            transition: background 0.3s;
            border-radius: 6px;
