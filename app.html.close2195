                document.getElementById('optimizationResults').style.display = 'none';
            }

            async function optimizeForJob() {
                const jobDescription = document.getElementById('jobDescriptionInput').value.trim();
                if (!jobDescription) {
                    alert('Veuillez coller la description de l\'offre');
                    return;
                }

                try {
                    const response = await authenticatedFetch('/ai/optimize-cv', {
                        method: 'POST',
                        body: JSON.stringify({
                            cvText: currentCVText,
                            jobDescription: jobDescription
                        })
                    });

                    const data = await response.json();
                    if (!response.ok) {
                        throw new Error(data.error || 'Erreur');
                    }

                    const analysis = data.analysis;

                    // Afficher les résultats
                    const resultsHTML = `
                    <div style="background: #E3F2FD; padding: 20px; border-radius: 8px; margin-bottom: 20px;">
                        <h4 style="margin-bottom: 10px;">📊 Score de correspondance: ${analysis.matchScore}%</h4>
                    </div>
                    <div style="margin-bottom: 20px;">
                        <h4>🔑 Mots-clés à ajouter</h4>
                        <div style="display: flex; flex-wrap: wrap; gap: 8px; margin-top: 10px;">
                            ${analysis.keywordsToAdd.map(k => `<span style="background: #FFE082; padding: 6px 12px; border-radius: 16px; font-size: 14px;">${k}</span>`).join('')}
                        </div>
                    </div>
                    <div style="margin-bottom: 20px;">
                        <h4>📝 Sections à améliorer</h4>
                        ${analysis.sectionsToImprove.map(s => `<div style="background: #FFF3E0; padding: 12px; margin: 8px 0; border-radius: 6px; border-left: 4px solid #FF9800;"><strong>${s.section}</strong>: ${s.suggestion}</div>`).join('')}
                    </div>
                    <div style="margin-bottom: 20px;">
                        <h4>❌ Compétences manquantes</h4>
                        ${analysis.missingSkills.map(s => `<div style="background: #FFEBEE; padding: 10px; margin: 6px 0; border-radius: 6px;">${s}</div>`).join('')}
                    </div>
                    <div style="margin-bottom: 20px;">
                        <h4>✅ Points forts à mettre en avant</h4>
                        ${analysis.strengthsToEmphasize.map(s => `<div style="background: #E8F5E9; padding: 10px; margin: 6px 0; border-radius: 6px;">${s}</div>`).join('')}
                    </div>
                    <div style="background: #F5F5F5; padding: 15px; border-radius: 8px;">
                        <h4>💡 Conseil global</h4>
                        <p style="line-height: 1.6; margin-top: 10px;">${analysis.overallAdvice}</p>
                    </div>
                `;

                    document.getElementById('optimizationContent').innerHTML = resultsHTML;
                    document.getElementById('optimizationResults').style.display = 'block';

                } catch (error) {
                    console.error('Erreur optimisation:', error);
                    alert('Erreur lors de l\'optimisation: ' + error.message);
                }
            }

            // Afficher le bouton optimisation pour Premium/Pro
            function updateOptimizeButton() {
                const user = getUser();
                const btn = document.getElementById('optimizeForJobBtn');
                if (btn && user && (user.tier === 'premium' || user.tier === 'pro')) {
                    btn.style.display = 'inline-block';
                }
            }

            // Appeler au chargement
            updateOptimizeButton();

    </script>
    <!-- Système de Notifications -->
    <script src="public/js/notifications.js"></script>
    <script src="public/js/favorites-badge.js"></script>
</body>

</html>